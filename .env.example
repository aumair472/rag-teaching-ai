# ============================================================
# RAG Teaching Assistant - Environment Configuration
# ============================================================
# Copy this file to .env and update values as needed.
# For local dev: Use redis://localhost:6379/0
# For Docker:    Use redis://redis:6379/0
# ============================================================

# === OpenAI ===
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# === Redis ===
# For Docker: redis://redis:6379/0
# For Local:  redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# === Embedding ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# === Cross-Encoder ===
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# === Retrieval ===
TOP_K=10
TOP_N_RERANK=5
SIMILARITY_THRESHOLD=0.3

# === FAISS ===
FAISS_INDEX_PATH=data/faiss_index.bin
FAISS_METADATA_PATH=data/metadata.pkl

# === Chunking ===
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# === Memory ===
MAX_CONVERSATION_HISTORY=10

# === Rate Limiting ===
RATE_LIMIT=20/minute

# === Voice Agent ===
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1-hd
TTS_VOICE=alloy

# === App ===
APP_NAME=RAG Teaching Assistant
APP_VERSION=1.0.0
LOG_LEVEL=INFO
